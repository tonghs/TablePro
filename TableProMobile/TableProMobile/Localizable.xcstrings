    "All data in \"%@\" will be permanently deleted." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "\"%@\" içindeki tüm veriler kalıcı olarak silinecektir."
          }
