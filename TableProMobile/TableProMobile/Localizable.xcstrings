    "A fast, lightweight database client for your iPhone and iPad." : {
      "localizations" : {
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "iPhone ve iPad için hızlı, hafif veritabanı istemcisi."
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ứng dụng quản lý cơ sở dữ liệu nhanh và nhẹ cho iPhone và iPad."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "适用于iPhone和iPad的快速轻量数据库客户端。"
          }
        }
      }
    },
